APP_NAME=Bridge AI
APP_VERSION=0.1.0
APP_DESCRIPTION=AI-powered operations infrastructure for community organizations.

ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

DATABASE_URL=sqlite:///./bridge_ai.db
DATABASE_ECHO=false

AI_PROVIDER=fake
AI_MODEL=fake-document-analyzer-v1
ANTHROPIC_API_KEY=

DOCUMENT_MAX_UPLOAD_BYTES=5000000
AI_MAX_DOCUMENT_CHARACTERS=50000