# --------------------------------------------------
# Application
# --------------------------------------------------

APP_NAME=Bridge AI
APP_VERSION=0.1.0
APP_DESCRIPTION=AI-powered operations infrastructure for community organizations.

# Supported values: development, testing, production
ENVIRONMENT=development
DEBUG=true

API_V1_PREFIX=/api/v1


# --------------------------------------------------
# Cross-Origin Resource Sharing
# --------------------------------------------------

# JSON-formatted list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]


# --------------------------------------------------
# Database
# --------------------------------------------------

# Local development
DATABASE_URL=sqlite:///./bridge_ai.db

# Production PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://username:password@host:5432/database_name

DATABASE_ECHO=false


# --------------------------------------------------
# AI Provider
# --------------------------------------------------

# Supported values: fake, anthropic
AI_PROVIDER=fake

AI_MODEL=fake-document-analyzer-v1

# Required only when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=


# --------------------------------------------------
# Document Processing
# --------------------------------------------------

# Maximum uploaded document size in bytes
DOCUMENT_MAX_UPLOAD_BYTES=5000000

# Maximum number of document characters sent for analysis
AI_MAX_DOCUMENT_CHARACTERS=50000